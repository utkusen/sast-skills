# macOS / Windows junk
.DS_Store
Thumbs.db
Desktop.ini

# Node
node_modules/
*.tgz
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Env / secrets — KRITIK for a public repo
.env
.env.*
!.env.example

# Credentials / keys — NEVER commit
.npmrc
.yarnrc
.pypirc
*.pem
*.key
*.p12
*.pfx
*.jks
*.keystore
id_rsa*
id_ed25519*

# Build artefacts
dist/
build/
out/
*.tsbuildinfo

# Editor / IDE caches
.vscode/
.idea/
*.swp
*.swo
*~

# Linter / test / tool caches
coverage/
.nyc_output/
*.lcov
.vite/
.vitest-cache/
.cache/
.eslintcache
.stylelintcache

# Yarn PnP / Yarn Berry
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/releases
!.yarn/plugins
!.yarn/sdks
!.yarn/versions

# Husky internals
.husky/_/

# Python tooling (used by ad-hoc scripts)
__pycache__/
*.pyc
*.pyo

# Ad-hoc artefacts that shouldn't land in the repo
*.log
*.bak
*.orig
*.tmp
tmp/
temp/

# TDD Guard local state (per-machine, ephemeral)
/.claude/

# SAST output (produced when this repo scans itself or a user's project)
sast/
